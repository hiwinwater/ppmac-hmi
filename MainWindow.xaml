<Window x:Class="PPMAC_HMI.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
 Title="PPMAC HMI" Height="650" Width="1000">

<Grid>
<Grid.ColumnDefinitions>
<ColumnDefinition Width="250"/>
<ColumnDefinition Width="*"/>
</Grid.ColumnDefinitions>

<!-- 左側參數 -->
<StackPanel Grid.Column="0" Margin="10">
<TextBlock Text="參數設定" FontSize="16"/>
<TextBox Name="txtStepAngle" Text="30" />
<TextBox Name="txtBacklash" Text="5" />
<TextBox Name="txtStepCount" Text="12" />
<TextBox Name="txtLapCount" Text="3" />
<TextBox Name="txtSpeed" Text="1000" />

<Button Content="Apply" Click="Apply_Click" Margin="0,10,0,0"/>
<Button Content="Start" Click="Start_Click"/>
<Button Content="Stop" Click="Stop_Click"/>
</StackPanel>

<!-- 右側圖表 -->
<lvc:CartesianChart Grid.Column="1" Name="Chart">
<lvc:CartesianChart.Series>
<lvc:LineSeries Title="Position" Values="{Binding PosValues}"/>
</lvc:CartesianChart.Series>
</lvc:CartesianChart>
</Grid>
</Window>
